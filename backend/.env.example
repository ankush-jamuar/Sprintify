# Server
PORT=5000
NODE_ENV=development

# Database (MongoDB Atlas for production)
MONGO_URI=mongodb://localhost:27017/sprintify

# Authentication
JWT_SECRET=your_secure_jwt_secret_change_me_in_production

# AI (Groq)
GROQ_API_KEY=your_groq_api_key

# File Storage (Cloudinary)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# GitHub Integration (optional)
GITHUB_APP_ID=
GITHUB_APP_SECRET=

# Frontend URL (comma-separated for multiple origins)
# Example: https://sprintify.vercel.app,http://localhost:5173
CLIENT_URL=http://localhost:5173
